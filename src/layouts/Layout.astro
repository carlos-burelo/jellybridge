---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props { title: string }
const { title } = Astro.props;

const nav = [
  { href: '/', label: 'Descargar' },
  { href: '/progress', label: 'Progreso' },
  { href: '/settings', label: 'Ajustes' },
];
---
<!doctype html>
<html lang="es" class="h-full bg-zinc-950 text-zinc-100 antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — JellyBridge</title>
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <ClientRouter />
  </head>
  <body class="h-full flex flex-col">
    <header class="border-b border-zinc-800/60 px-6 py-3.5 flex items-center gap-8 bg-zinc-950/80 backdrop-blur sticky top-0 z-10">
      <a href="/" class="flex items-center gap-2 group" transition:name="logo">
        <img src="/icon.jpg" alt="JellyBridge" class="w-6 h-6 rounded-md object-cover" />
        <span class="text-sm font-semibold tracking-tight text-white">JellyBridge</span>
      </a>
      <nav class="flex gap-1">
        {nav.map(({ href, label }) => {
          const active = Astro.url.pathname === href;
          return (
            <a
              href={href}
              class={`text-sm px-3 py-1.5 rounded-md transition-colors ${active ? 'bg-zinc-800 text-white font-medium' : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'}`}
            >
              {label}
            </a>
          );
        })}
      </nav>
    </header>
    <main class="flex-1 p-6 overflow-auto max-w-2xl w-full mx-auto" transition:animate="fade">
      <slot />
    </main>
  </body>
</html>
