---
import Layout from '../layouts/Layout.astro';
import LogViewer from '../components/LogViewer';
import { getEntries } from '../lib/logger';

const initial = getEntries(100);
---
<Layout title="Logs">
  <div class="flex flex-col gap-4 h-[calc(100vh-8rem)]">
    <div>
      <h1 class="text-2xl font-bold">Logs</h1>
      <p class="text-sm text-zinc-500 mt-1">Diagnóstico en tiempo real.</p>
    </div>
    <LogViewer client:only="react" initial={initial} />
  </div>
</Layout>
